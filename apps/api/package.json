    "@kiotviet-lite/shared": "workspace:*",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.45.0",
    "hono": "^4.12.0",
    "hono-rate-limiter": "^0.5.3",
    "jsonwebtoken": "^9.0.3",
    "pino": "^10.3.1",
    "pino-roll": "^4.0.0",
    "postgres": "^3.4.0",
    "uuidv7": "^1.2.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.4",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.31.0",
